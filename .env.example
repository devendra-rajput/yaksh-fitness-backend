NODE_ENV = "development"
APPLICATION_PORT = "8000"
APP_NAME = "Yaksh Fitness"
API_VER = "1.0.0"
LOG_DISABLE = "true"
LOG_LEVEL = "info"
LOG_SERVICE_NAME = "yaksh-fitness-api"

# MongoDB
DATABASE_URL = "mongodb://localhost:27017/yaksh-fitness"

# Email (SMTP)
MAIL_HOST = "smtp.gmail.com"
MAIL_PORT = "587"
MAIL_USERNAME = "#########"
MAIL_PASSWORD = "#########"
MAIL_FROM = "Yaksh Fitness <noreply@yakshlabs.com>"
SUPPORT_MAIL = "support@yakshlabs.com"

# Redis
REDIS_URL = "127.0.0.1"
REDIS_PORT = "6379"
REDIS_EXPIRATION = "604800"           # 7 days (default TTL for generic cached data)

# AWS S3
AWS_S3_BUCKET_NAME = "#########"
AWS_REGION = "#########"
AWS_ACCESS_KEY = "#########"
AWS_SECRET_ACCESS_KEY = "#########"

# JWT
JWT_TOKEN_KEY = "#########"           # Secret for ACCESS tokens
JWT_REFRESH_KEY = "#########"         # Secret for REFRESH tokens (use a different value!)

# Google OAuth
GOOGLE_CLIENT_ID = "#########"        # Google API Console → OAuth 2.0 Client ID

# CORS
CORS_ORIGINS = "http://localhost:3000,http://127.0.0.1:3000"

# SSL (production only)
SSL_STATUS = "false"
SSL_KEY_PEM_PATH = "/path/to/key.pem"
SSL_CERT_PEM_PATH = "/path/to/cert.pem"

# Rate Limiter (global – applied to every request)
RATE_LIMIT_POINTS = "200"             # requests allowed
RATE_LIMIT_DURATION = "1"            # per N seconds
RATE_LIMIT_BLOCK_DURATION = "10"     # seconds to block after exceeding