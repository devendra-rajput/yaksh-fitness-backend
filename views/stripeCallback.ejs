<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Query Parameters</title>
</head>
<body>
    <h1>Query Parameters</h1>

    <ul>
        <% for (let key in queryParams) { %>
            <li><strong><%= key %>:</strong> <%= queryParams[key] %></li>
        <% } %>
    </ul>

</body>
</html>
